{
  "name": "lyra",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "editor:dev": "bun run --cwd apps/layout-editor tauri dev",
    "editor:build": "bun run --cwd apps/layout-editor tauri build",
    "editor:check": "bun run --cwd apps/layout-editor check",
    "lint": "svelte-kit sync && eslint .",
    "lint:fix": "svelte-kit sync && eslint . --fix",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "tauri": "tauri",
    "scenes:compile": "bun run scripts/compile-scenes.ts",
    "scenes:watch": "bun run scripts/compile-scenes.ts --watch",
    "dev:tauri": "bun run scenes:compile && bun run dev",
    "build:tauri": "bun run scenes:compile && bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
    "rust:fmt:fix": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "lint:staged": "lint-staged",
    "lint:all": "bun run lint && bun run format:check && bun run rust:fmt && bun run rust:lint",
    "prepare": "husky"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "bun-types": "^1.3.14",
    "chokidar": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.7.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.0.3",
    "vitest": "^4.1.6",
    "yaml": "^2.9.0"
  }
}
