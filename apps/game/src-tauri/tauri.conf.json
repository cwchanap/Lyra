{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lyra",
  "version": "0.1.0",
  "identifier": "com.chanwaichan.lyra",
  "build": {
    "beforeDevCommand": "bun run scenes:compile && bun run dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:tauri",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "lyra",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/scenes/**/*", "resources/assets/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
