{
  "name": "@lyra/layout-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --cwd ../.. dev:editor",
    "dev:frontend": "vite dev --host 127.0.0.1",
    "dev:tauri": "bun run --cwd ../.. scenes:compile && tauri dev -c src-tauri/tauri.dev.conf.json",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "tauri": "tauri",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
    "rust:fmt:fix": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings"
  },
  "dependencies": {
    "@lyra/asset-paths": "workspace:*",
    "@lyra/game": "workspace:*",
    "@lyra/scene-types": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "svelte": "^5.0.0",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2"
  }
}
