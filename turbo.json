{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**", "dist/**", ".svelte-kit/**"]
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "preview": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test:e2e:ui": {
      "dependsOn": ["build"],
      "cache": false
    },
    "dev:frontend": {
      "cache": false,
      "persistent": true
    },
    "dev:tauri": {
      "cache": false,
      "persistent": true
    },
    "check:watch": {
      "cache": false,
      "persistent": true
    },
    "rust:fmt": {
      "cache": false
    },
    "rust:fmt:fix": {
      "cache": false
    },
    "rust:lint": {
      "cache": false
    }
  }
}
